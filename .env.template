# ==============================================================================
# ResumeCraft Environment Configuration
# Copy this file to '.env' and fill in the values for your chosen provider.
# ==============================================================================

# ------------------------------------------------------------------------------
# General Settings
# ------------------------------------------------------------------------------
# Active provider: Choose 'azure', 'openai', 'gemini', or 'anthropic'
LLM_PROVIDER=openai

# Temperature for LLM generation (e.g. 0.0 to 1.0)
TEMPERATURE=0.8

# ------------------------------------------------------------------------------
# Azure OpenAI Configuration (Default)
# ------------------------------------------------------------------------------
AZURE_DEPLOYMENT=
AZURE_API_KEY=your_azure_api_key_here
AZURE_API_VERSION=2024-12-01-preview
AZURE_ENDPOINT=https://your-resource.openai.azure.com/

# ------------------------------------------------------------------------------
# OpenAI Configuration
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------------------------
# Google Gemini Configuration
# ------------------------------------------------------------------------------
# Note: Ensure you run `pip install langchain-google-genai` if using Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ------------------------------------------------------------------------------
# Anthropic Claude Configuration
# ------------------------------------------------------------------------------
# Note: Ensure you run `pip install langchain-anthropic` if using Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
